project/

# ── Terraform State ───────────────────────────────────────────────────────────
# State files contain sensitive resource details and must never be committed.
# Remote state (S3) is the source of truth.
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# ── Terraform Working Directory ───────────────────────────────────────────────
# Generated by terraform init. Contains provider binaries and cached modules.
.terraform/
.terraform.lock.hcl

# ── Variable Values ───────────────────────────────────────────────────────────
# Contains secrets (DB password, SSH CIDR). NEVER commit this file.
# Use terraform.tfvars.example as the committed template.
terraform.tfvars
*.tfvars
*.tfvars.json

# ── Plan Files ────────────────────────────────────────────────────────────────
# Saved plan files may contain sensitive values.
tfplan
*.tfplan

# ── SSH Keys ──────────────────────────────────────────────────────────────────
*.pem
*.key
*_rsa
*_ed25519

# ── Runtime Environment ───────────────────────────────────────────────────────
# Contains secret ARNs and runtime config. Use .env.example as the template.
.env

# ── Procedure Notes ───────────────────────────────────────────────────────────
# Internal step-by-step walkthroughs. Not part of the project deliverables.
procedure/



